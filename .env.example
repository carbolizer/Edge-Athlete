# .env.example — RUNNABLE local defaults for the Edge Athlete base station.
#
# QUICK START (fresh clone):
#   cp .env.example .env          # .env is gitignored; this leaves the repo clean
#   docker compose up --build     # first boot builds images + runs migrations
# Then open http://localhost/  (nginx publishes port 80).
#
# These are DEV-SAFE values only — the base station is an offline private network,
# so there are no real secrets here. Replace SECRET_KEY and POSTGRES_PASSWORD before
# any shared/production deployment. The hostnames (`postgres`, `mosquitto`) are the
# docker-compose service names — the stack reaches services by name on its private
# network, so do NOT change them to localhost.

# Django
SECRET_KEY=django-insecure-edgeathlete-dev-key-replace-for-prod
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,basestation,192.168.4.1

# PostgreSQL (only reachable inside the Docker network; not published to the host)
POSTGRES_DB=edgeathlete
POSTGRES_USER=edgeathlete_user
POSTGRES_PASSWORD=supersafepw
DATABASE_URL=postgresql://edgeathlete_user:supersafepw@postgres:5432/edgeathlete

# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=1883

# Ntfy (optional ops-alert channel; being retired in merge phase P2 / D5).
# Set your own private topic locally if you want alerts — do NOT commit a real
# topic name, an ntfy.sh topic string is effectively its access token.
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=edgeathlete-alerts-changeme

# API
VITE_API_URL=http://localhost/api
