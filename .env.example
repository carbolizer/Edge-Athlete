# .env.example — the committed blueprint for the real .env.
# This file is the labeled-but-empty version of .env: it shows every setting the
# stack needs to run, without any real secrets. Copy it to `.env` and fill in the
# blanks. `.env` itself is gitignored so real passwords never land in the repo.

# Django
SECRET_KEY=
DEBUG=
ALLOWED_HOSTS=

# PostgreSQL
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
DATABASE_URL=

# MQTT
MQTT_HOST=
MQTT_PORT=

# Ntfy (optional ops-alert channel)
NTFY_URL=
NTFY_TOPIC=

# API
VITE_API_URL=
