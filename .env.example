# .env.example — runnable local defaults and the blueprint for the real .env.
# Copy it to `.env`; setup.sh replaces the local-only credentials for a Pi
# deployment. `.env` itself is gitignored so generated secrets stay out of git.

# Local development defaults. Replace secrets before any shared deployment.
COMPOSE_PROJECT_NAME=edgeathlete
EDGEATHLETE_BIND_ADDRESS=127.0.0.1
SECRET_KEY=change-me-local-only
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,basestation,192.168.4.1
# IANA timezone used for report local_date grouping.
DJANGO_TIME_ZONE=UTC

# PostgreSQL
POSTGRES_DB=edgeathlete
POSTGRES_USER=edgeathlete
POSTGRES_PASSWORD=change-me-local-only
DATABASE_URL=postgresql://edgeathlete:change-me-local-only@postgres:5432/edgeathlete

# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=1883

# API
VITE_API_URL=/api

# Host port for the Edge Athlete website. This avoids collisions with old port-80 projects.
EDGEATHLETE_HTTP_PORT=8081
